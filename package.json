{
  "name": "strategy-cockpit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "An inspector for a strategic feedback loop. Prototype.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage --coverage.provider=v8 --coverage.include='src/lib/**' --coverage.include='src/mirrors/**'",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@xyflow/react": "^12.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@amiceli/vitest-cucumber": "^5.2.1",
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^3.2.4"
  }
}
